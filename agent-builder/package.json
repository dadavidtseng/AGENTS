{
  "name": "agent-builder",
  "version": "0.1.0",
  "description": "KĀDI agent for game lifecycle management - shutdown, rebuild (MSBuild), and relaunch DaemonAgent",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "kadi",
    "agent",
    "builder",
    "msbuild",
    "game-lifecycle"
  ],
  "author": "Yu-Wei Tseng",
  "license": "MIT",
  "dependencies": {
    "@kadi.build/core": "latest",
    "agents-library": "^0.1.11",
    "archiver": "^7.0.1",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
