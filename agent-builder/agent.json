{
  "name": "agent-builder",
  "type": "agent",
  "version": "0.1.0",
  "description": "KADI agent for game lifecycle management - shutdown, rebuild (MSBuild), and relaunch DaemonAgent",
  "entrypoint": "dist/index.js",
  "abilities": {
    "ability-log": "*"
  },
  "scripts": {
    "preflight": "node --version",
    "setup": "npm install && npm run build",
    "build": "npx tsc",
    "start": "node dist/index.js",
    "dev": "npx tsx watch src/index.ts",
    "clean": "rm -rf node_modules dist package-lock.json"
  }
}
