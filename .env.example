# Deploy Ability Configuration
# This is a template file - copy to .env and fill in your values

# =============================================================================
# KADI Configuration
# =============================================================================

# Mode: 'native', 'stdio', or 'broker'
# - native: Direct loading for development
# - stdio: Standard I/O communication
# - broker: Network discovery via KADI broker
KADI_MODE=broker

# KADI Broker URL (required when KADI_MODE=broker)
KADI_BROKER_URL=ws://localhost:8080/kadi

# =============================================================================
# AKASH NETWORK CONFIGURATION
# =============================================================================

# Akash Network RPC endpoint
# AKASH_RPC_ENDPOINT=https://rpc.akashnet.net:443

# Akash Network API endpoint
# AKASH_API_ENDPOINT=https://api.akashnet.net

# Akash wallet mnemonic (24-word seed phrase)
# WARNING: Keep this secret! Never commit to version control
# AKASH_WALLET_MNEMONIC=your 24 word seed phrase here

# Akash certificate path (optional, will be auto-generated if not provided)
# AKASH_CERTIFICATE_PATH=

# Default deployment profile
# AKASH_DEFAULT_PROFILE=production

# Maximum bid price in uakt (optional)
# AKASH_MAX_BID_PRICE=1000000

# Provider blacklist (comma-separated addresses)
# AKASH_PROVIDER_BLACKLIST=

# Provider whitelist (comma-separated addresses, takes precedence over blacklist)
# AKASH_PROVIDER_WHITELIST=

# =============================================================================
# LOCAL DOCKER CONFIGURATION
# =============================================================================

# Container engine: 'docker' or 'podman'
LOCAL_ENGINE=docker

# Docker host (optional, defaults to system Docker daemon)
# DOCKER_HOST=unix:///var/run/docker.sock

# Default local deployment profile
LOCAL_DEFAULT_PROFILE=local-dev

# =============================================================================
# DEPLOYMENT DEFAULTS
# =============================================================================

# Enable monitoring by default
DEPLOY_MONITOR_READINESS=true

# Dry run mode (set to 'true' to prevent actual deployments)
DEPLOY_DRY_RUN=false

# Default project root (optional, defaults to current directory)
# DEPLOY_PROJECT_ROOT=

# =============================================================================
# LOGGING & DEBUGGING
# =============================================================================

# Log level: 'debug', 'info', 'warn', 'error'
LOG_LEVEL=info

# Enable verbose logging
# DEBUG=deploy-ability:*
