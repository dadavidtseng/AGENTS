# Slack API Credentials
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_SIGNING_SECRET=your-signing-secret-here

# Slack HTTP Events API Configuration
# Port for the local HTTP server (ngrok tunnels to this)
SLACK_HTTP_PORT=3700

# KĀDI Broker Configuration
# WebSocket URL for KĀDI broker connection (e.g., ws://localhost:8080)
KADI_BROKER_URL=ws://localhost:8080

# Slack Bot User ID for event routing (get from Slack app settings)
# Format: U followed by alphanumeric characters (e.g., U01234ABCD)
SLACK_BOT_USER_ID=U01234ABCD

# Logging Configuration
LOG_LEVEL=info
