# Discord Bot Token (from Discord Developer Portal)
DISCORD_TOKEN=YOUR_DISCORD_BOT_TOKEN_HERE

# Discord Bot User ID (numeric ID of the bot user)
DISCORD_BOT_USER_ID=YOUR_DISCORD_BOT_USER_ID_HERE

# KĀDI Broker WebSocket URL (for event publishing) - must include /kadi path
KADI_BROKER_URL=ws://localhost:8080/kadi

# Optional: Discord Guild ID (server ID) - if bot should only work in specific server
DISCORD_GUILD_ID=YOUR_DISCORD_GUILD_ID_HERE

# MCP Log Level (debug, info, warn, error)
MCP_LOG_LEVEL=info
