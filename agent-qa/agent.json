{
  "name": "agent-qa",
  "type": "agent",
  "version": "0.3.1",
  "entrypoint": "dist/index.js",
  "scripts": {
    "preflight": "node -e \"const fs=require('fs');if(!fs.existsSync('node_modules')){console.error('Dependencies not installed. Run: npm install');process.exit(1)}console.log('✓ Dependencies OK')\"",
    "setup": "npx tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest"
  },
  "build": {
    "default": {
      "from": "node:20-alpine",
      "cli": "latest",
      "run": [
        "npm ci --include=dev",
        "npx tsc",
        "npm prune --omit=dev"
      ],
      "env": {
        "NODE_ENV": "production"
      }
    }
  },
  "abilities": {
    "secret-ability": "^0.9.4",
    "ability-file-local": "^0.1.1",
    "ability-eval": "*",
    "ability-vision": "*",
    "ability-file-cloud": "*",
    "ability-file-remote": "*"
  },
  "brokers": {
    "local": "ws://localhost:8080/kadi",
    "remote": "wss://broker.dadavidtseng.com/kadi"
  }
}
