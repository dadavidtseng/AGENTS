# Agent role: artist | designer | programmer
AGENT_ROLE=programmer

# KĀDI broker WebSocket URL
KADI_BROKER_URL=ws://localhost:8080/kadi

# Comma-separated list of broker networks to join
# qa: receive task.review_requested events
# quest: query quest/task details from mcp-server-quest
# git: retrieve diffs from mcp-server-git
KADI_NETWORK=qa,quest,git
