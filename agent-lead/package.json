{
  "name": "agent-lead",
  "version": "0.3.5",
  "description": "Orchestration agent - KĀDI agent-lead for task assignment, dependency management, verification, and PR creation",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "start:artist": "AGENT_ROLE=artist node dist/index.js",
    "start:designer": "AGENT_ROLE=designer node dist/index.js",
    "start:programmer": "AGENT_ROLE=programmer node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "dev:artist": "AGENT_ROLE=artist tsx watch src/index.ts",
    "dev:designer": "AGENT_ROLE=designer tsx watch src/index.ts",
    "dev:programmer": "AGENT_ROLE=programmer tsx watch src/index.ts",
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest"
  },
  "keywords": [
    "kadi",
    "agent",
    "lead",
    "orchestrator",
    "mcp",
    "typescript"
  ],
  "author": "Yu-Wei Tseng",
  "license": "Apache License 2.0",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@kadi.build/core": "latest",
    "agents-library": "latest",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^8.57.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
