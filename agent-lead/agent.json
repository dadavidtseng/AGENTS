{
  "name": "agent-lead",
  "type": "agent",
  "version": "0.3.0",
  "entrypoint": "dist/index.js",
  "scripts": {
    "preflight": "node -e \"const fs=require('fs');if(!fs.existsSync('node_modules')){console.error('Dependencies not installed. Run: npm install');process.exit(1)}console.log('✓ Dependencies OK')\"",
    "setup": "npm run build",
    "start": "node dist/index.js",
    "start:artist": "AGENT_ROLE=artist node dist/index.js",
    "start:designer": "AGENT_ROLE=designer node dist/index.js",
    "start:programmer": "AGENT_ROLE=programmer node dist/index.js",
    "dev": "npx tsx watch src/index.ts",
    "dev:artist": "AGENT_ROLE=artist npx tsx watch src/index.ts",
    "dev:designer": "AGENT_ROLE=designer npx tsx watch src/index.ts",
    "dev:programmer": "AGENT_ROLE=programmer npx tsx watch src/index.ts",
    "build": "npx tsc",
    "type-check": "npx tsc --noEmit",
    "lint": "npx eslint src --ext .ts",
    "test": "npx vitest",
    "clean": "rm -rf node_modules dist abilities agent-lock.json package-lock.json"
  },
  "build": {
    "default": {
      "from": "node:20-alpine",
      "cli": "latest",
      "run": [
        "npm ci --include=dev",
        "kadi install kadi-secret",
        "kadi install",
        "npx tsc",
        "npm prune --omit=dev"
      ],
      "env": {
        "NODE_ENV": "production"
      }
    }
  },
  "deploy": {
    "akash-programmer": {
      "target": "akash",
      "network": "mainnet",
      "deposit": "10",
      "blacklist": [
        "akash1sevd2ymtty3dpq9ycxgkhuzzk4fe6mchqdwd4e",
        "akash14w36hwrtuqqa3j92fa8ctcxlhjgvr3a0zpp7cj"
      ],
      "engine": "podman",
      "services": {
        "app": {
          "image": "agent-lead:0.3.0",
          "command": ["sh", "-c", "kadi secret receive --vault anthropic --vault model-manager && kadi run start:programmer"],
          "expose": [
            {
              "port": 3000,
              "as": 3000,
              "to": [{ "global": true }]
            }
          ],
          "env": [
            "NODE_ENV=production",
            "AGENT_ROLE=programmer"
          ],
          "resources": {
            "cpu": 0.5,
            "memory": "512Mi",
            "ephemeralStorage": "1Gi"
          },
          "pricing": { "amount": "500", "denom": "uact" }
        }
      },
      "secrets": {
        "vaults": [
          {
            "vault": "anthropic",
            "required": ["ANTHROPIC_API_KEY"]
          },
          {
            "vault": "model-manager",
            "required": ["MODEL_MANAGER_API_KEY", "MODEL_MANAGER_BASE_URL"]
          }
        ],
        "delivery": "broker"
      }
    },
