{
  "name": "agent-lead",
  "version": "0.2.0",
  "scripts": {
    "preflight": "node -e \"const fs=require('fs');if(!fs.existsSync('node_modules')){console.error('Dependencies not installed. Run: npm install');process.exit(1)}console.log('✓ Dependencies OK')\"",
    "setup": "npx tsc",
    "start": "node dist/index.js",
    "start:artist": "AGENT_ROLE=artist node dist/index.js",
    "start:designer": "AGENT_ROLE=designer node dist/index.js",
    "start:programmer": "AGENT_ROLE=programmer node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "dev:artist": "AGENT_ROLE=artist tsx watch src/index.ts",
    "dev:designer": "AGENT_ROLE=designer tsx watch src/index.ts",
    "dev:programmer": "AGENT_ROLE=programmer tsx watch src/index.ts",
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest"
  },
  "build": {
    "default": {
      "from": "node:20-alpine",
      "cli": "latest",
      "run": [
        "npm ci --include=dev",
        "npx tsc",
        "npm prune --omit=dev"
      ],
      "env": {
        "NODE_ENV": "production"
      }
    }
  },
  "abilities": {
    "secret-ability": "^0.9.3"
  },
  "brokers": {
    "default": "ws://localhost:8080/kadi"
  }
}
