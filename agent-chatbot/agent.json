{
  "name": "agent-chatbot",
  "type": "agent",
  "version": "0.1.4",
  "entrypoint": "dist/index.js",
  "scripts": {
    "preflight": "node -e \"const fs=require('fs');if(!fs.existsSync('node_modules')){console.error('Dependencies not installed. Run: npm install');process.exit(1)}console.log('✓ Dependencies OK')\"",
    "setup": "npx tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest"
  },
  "build": {
    "default": {
      "from": "node:20-alpine",
      "cli": "latest",
      "run": [
        "npm ci --include=dev",
        "kadi install kadi-secret",
        "kadi install",
        "npx tsc",
        "npm prune --omit=dev"
      ],
      "env": {
        "NODE_ENV": "production"
      }
    }
  },
  "abilities": {
    "secret-ability": "*"
  },
  "deploy": {
    "akash-mainnet": {
      "target": "akash",
      "network": "mainnet",
      "deposit": "10",
      "blacklist": [
        "akash1sevd2ymtty3dpq9ycxgkhuzzk4fe6mchqdwd4e",
        "akash14w36hwrtuqqa3j92fa8ctcxlhjgvr3a0zpp7cj"
      ],
      "engine": "podman",
      "services": {
        "app": {
          "image": "agent-chatbot:0.1.4",
          "command": ["sh", "-c", "kadi secret receive --vault chatbot && kadi run start"],
          "expose": [
            {
              "port": 3000,
              "as": 3000,
              "to": [
                {
                  "global": true
                }
              ]
            }
          ],
          "env": [
            "NODE_ENV=production"
          ],
          "resources": {
            "cpu": 0.5,
            "memory": "512Mi",
            "ephemeralStorage": "1Gi"
          },
          "pricing": { "amount": "500", "denom": "uact" }
        }
      },
      "secrets": {
        "vaults": [
          {
            "vault": "chatbot",
            "required": [
              "DISCORD_TOKEN",
              "SLACK_BOT_TOKEN",
              "SLACK_SIGNING_SECRET"
            ]
          }
        ],
        "delivery": "broker"
      }
    }
  },
  "brokers": {
    "remote": "wss://broker.dadavidtseng.com/kadi"
  }
}
