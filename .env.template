# TypeScript Agent Template Configuration
# Copy this file to .env and fill in your values

# ============================================================================
# Agent Configuration
# ============================================================================

# Agent unique identifier (used in KĀDI network)
AGENT_NAME=typescript-agent

# Agent version
AGENT_VERSION=1.0.0

# ============================================================================
# KĀDI Broker Configuration
# ============================================================================

# KĀDI Broker WebSocket URL
KADI_BROKER_URL=ws://localhost:8080

# Networks to join (comma-separated)
# Available networks: global, text, git, slack, discord, your-custom-network
KADI_NETWORK=global,text

# ============================================================================
# Git MCP Server Configuration (Optional)
# ============================================================================

# Base directory for Git operations
# Set to parent directory to allow access to sibling repositories
GIT_BASE_DIR=

# Git user configuration (used by @cyanheads/git-mcp-server)
GIT_USERNAME=Your Name
GIT_EMAIL=your.email@example.com

# ============================================================================
# MCP Server Configuration
# ============================================================================

MCP_LOG_LEVEL=info
MCP_TRANSPORT_TYPE=stdio
MCP_RESPONSE_FORMAT=auto

# ============================================================================
# Bot Integration (Optional)
# ============================================================================

# Claude API key for bot responses
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Enable/disable bot features
# Set to 'true' or 'false'
ENABLE_SLACK_BOT=false
ENABLE_DISCORD_BOT=false

# Bot Claude Configuration
# Claude model to use for processing mentions
BOT_CLAUDE_MODEL=claude-3-haiku-20240307

# Maximum tokens for Claude API responses
BOT_CLAUDE_MAX_TOKENS=4096

# Bot Timing Configuration
# Polling interval in milliseconds (5000 = 5 seconds)
BOT_POLL_INTERVAL_MS=5000

# Tool invocation timeout in milliseconds (10000 = 10 seconds)
BOT_TOOL_TIMEOUT_MS=10000

# ============================================================================
# Bot Resilience Configuration
# ============================================================================

# Maximum retry attempts for failed requests (default: 3)
BOT_MAX_RETRIES=3

# Base delay in milliseconds for exponential backoff (default: 1000)
# Retry delays: 1s, 2s, 4s
BOT_RETRY_BASE_DELAY_MS=1000

# Maximum failures before circuit breaker opens (default: 5)
BOT_CIRCUIT_BREAKER_MAX_FAILURES=5

# Circuit breaker reset time in milliseconds (default: 60000 = 1 minute)
BOT_CIRCUIT_BREAKER_RESET_MS=60000
