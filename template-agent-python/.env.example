# KĀDI Calculator Agent Configuration
# Copy this file to .env and configure for your environment

# KĀDI Broker WebSocket URL
# Default Python broker port: 8765
# Default TypeScript broker port: 8080
KADI_BROKER_URL=ws://localhost:8765

# Networks to join (comma-separated)
# Default: global,math
KADI_NETWORK=global,math

# Logging level
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
