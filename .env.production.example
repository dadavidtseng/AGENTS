# ============================================================================
# template-agent-typescript - Production Environment Configuration
# ============================================================================
# Copy this file to .env.production and fill in your actual values
# ============================================================================

# ----------------------------------------------------------------------------
# Agent Configuration
# ----------------------------------------------------------------------------
AGENT_NAME=template-typescript-agent
AGENT_VERSION=0.0.1
NODE_ENV=production

# ----------------------------------------------------------------------------
# Anthropic API Configuration (Required)
# ----------------------------------------------------------------------------
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ----------------------------------------------------------------------------
# Model Manager Configuration (Required)
# ----------------------------------------------------------------------------
MODEL_MANAGER_BASE_URL=https://your-model-manager-url.com
MODEL_MANAGER_API_KEY=your-model-manager-api-key-here

# ----------------------------------------------------------------------------
# Memory Configuration
# ----------------------------------------------------------------------------
# Local file storage path for short-term memory (JSON files)
MEMORY_DATA_PATH=/app/data/memory

# ArcadeDB Configuration for long-term memory
ARCADEDB_URL=http://arcadedb:2480
ARCADEDB_USERNAME=root
ARCADEDB_PASSWORD=playwithdata
ARCADEDB_DATABASE=memory

# ----------------------------------------------------------------------------
# Bot Configuration
# ----------------------------------------------------------------------------
# Feature flags
ENABLE_SLACK_BOT=true
ENABLE_DISCORD_BOT=true

# Slack Bot Configuration (REQUIRED when ENABLE_SLACK_BOT=true)
SLACK_BOT_USER_ID=your-slack-bot-user-id
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token

# Discord Bot Configuration (REQUIRED when ENABLE_DISCORD_BOT=true)
DISCORD_BOT_USER_ID=your-discord-bot-user-id
DISCORD_BOT_TOKEN=your-discord-bot-token

# Bot Behavior Configuration
BOT_CLAUDE_MODEL=claude-3-haiku-20240307
BOT_CLAUDE_MAX_TOKENS=4096
BOT_TOOL_TIMEOUT_MS=10000

# Bot Resilience Configuration
BOT_MAX_RETRIES=3
BOT_RETRY_BASE_DELAY_MS=1000
BOT_CIRCUIT_BREAKER_MAX_FAILURES=5
BOT_CIRCUIT_BREAKER_RESET_MS=60000

# ----------------------------------------------------------------------------
# KADI Broker Configuration (if using KADI ecosystem)
# ----------------------------------------------------------------------------
KADI_BROKER_URL=ws://kadi-broker:8080/kadi
KADI_NETWORK=global,text,git,slack,discord
KADI_DEBUG=false

# ----------------------------------------------------------------------------
# Git Configuration (if using git tools)
# ----------------------------------------------------------------------------
GIT_BASE_DIR=/app/repos
GIT_USERNAME='Your Name'
GIT_EMAIL=your-email@example.com

# ----------------------------------------------------------------------------
# MCP Server Configuration
# ----------------------------------------------------------------------------
MCP_LOG_LEVEL=info
MCP_TRANSPORT_TYPE=stdio
MCP_RESPONSE_FORMAT=auto

# ----------------------------------------------------------------------------
# TLS Configuration
# ----------------------------------------------------------------------------
# WARNING: Only disable in development/staging environments!
NODE_TLS_REJECT_UNAUTHORIZED=0
