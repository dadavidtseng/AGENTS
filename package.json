{
  "name": "calculator-agent",
  "version": "1.0.0",
  "description": "KĀDI calculator agent example for ProtogameJS3D - TypeScript implementation",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest"
  },
  "keywords": [
