{
  "name": "agent-producer",
  "version": "1.0.0",
  "description": "Agent orchestrator - KĀDI agent for coordinating worker agents via KĀDI protocol",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest",
    "miner": "tsx src/MinerAgent.ts",
    "miner:watch": "tsx watch src/MinerAgent.ts",
    "builder": "tsx src/BuilderAgent.ts"
  },
  "keywords": [
    "kadi",
    "agent",
    "mcp",
    "orchestrator",
    "multi-agent",
    "typescript"
  ],
  "author": "Yu-Wei Tseng",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@kadi.build/core": "file:../kadi/kadi-core",
    "@modelcontextprotocol/sdk": "1.24.0",
    "agents-library": "file:../agents-library",
    "dotenv": "^16.4.5",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "@vitest/coverage-v8": "^1.6.1",
    "eslint": "^8.56.0",
    "patch-package": "^8.0.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
