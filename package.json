{
  "name": "github-mcp-server",
  "version": "1.0.0",
  "mcpName": "github-mcp-server",
  "description": "A TypeScript MCP server for GitHub API operations (pull requests, issues, repos) via STDIO and Streamable HTTP.",
  "main": "dist/index.js",
  "files": ["dist"],
  "bin": {
    "github-mcp-server": "dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./*": "./dist/*"
  },
  "types": "dist/index.d.ts",
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target node --external pino --external pino-pretty --external @octokit/rest",
    "start": "bun ./dist/index.js",
    "start:stdio": "MCP_TRANSPORT_TYPE=stdio bun ./dist/index.js",
    "start:http": "MCP_TRANSPORT_TYPE=http bun ./dist/index.js",
    "dev": "bun --watch src/index.ts",
    "dev:stdio": "MCP_LOG_LEVEL=debug MCP_TRANSPORT_TYPE=stdio bun --watch src/index.ts",
    "dev:http": "MCP_LOG_LEVEL=debug MCP_TRANSPORT_TYPE=http bun --watch src/index.ts",
    "typecheck": "bunx tsc --noEmit",
    "lint": "bunx eslint .",
    "lint:fix": "bunx eslint . --fix",
    "rebuild": "rm -rf dist && bun run build"
  },
  "dependencies": {
    "@octokit/rest": "^22.0.0",
    "pino": "^10.1.0",
    "pino-pretty": "^13.1.2",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@hono/mcp": "^0.1.4",
    "@hono/node-server": "^1.19.5",
    "@modelcontextprotocol/sdk": "^1.20.2",
    "@types/bun": "^1.3.9",
    "@types/node": "^25.2.3",
    "dotenv": "^17.2.3",
    "hono": "^4.10.3",
    "tsyringe": "^4.10.0",
    "typescript": "^5.9.3",
    "zod": "^3.23.8"
  },
  "keywords": [
    "github",
    "mcp",
    "mcp-server",
    "pull-request",
    "ai-agent",
    "model-context-protocol",
    "typescript",
    "octokit"
  ],
  "license": "Apache-2.0",
  "packageManager": "bun@1.2.21",
  "engines": {
    "bun": ">=1.2.0",
    "node": ">=20.0.0"
  }
}
