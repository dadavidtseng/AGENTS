{
  "name": "mcp-server-quest",
  "type": "module",
  "version": "0.1.0",
  "description": "Comprehensive quest orchestration system with KĀDI broker integration",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:mcp": "tsx src/mcp-server.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:mcp": "node dist/mcp-server.js",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "test:watch": "vitest --watch",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "latest",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "latest",
    "@vitest/coverage-v8": "^4.0.18",
    "tsx": "latest",
    "typescript": "^5.3.0",
    "vitest": "^4.0.18"
  }
}
