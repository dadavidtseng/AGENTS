# Cloud File Manager Ability Configuration
# Copy this file to .env and customize the values

# =============================================================================
# KADI Configuration
# =============================================================================

# Transport mode: native, stdio, or broker
KADI_MODE=stdio

# Broker WebSocket URL (required when KADI_MODE=broker)
# KADI_BROKER_URL=ws://localhost:8080/kadi

# Network scope for this ability
# KADI_NETWORK=file-cloud

# Optional: Enable debug logging
# KADI_DEBUG=true

# =============================================================================
# DROPBOX CONFIGURATION
# =============================================================================

# Option 1: Long-lived Access Token (Simple but expires in 4 hours)
# Get from: https://www.dropbox.com/developers/apps
# DROPBOX_ACCESS_TOKEN=your_dropbox_access_token_here

# Option 2: OAuth with Refresh Tokens (Recommended for long-running processes)
# Tokens obtained through OAuth flow using setup-dropbox-oauth.js
DROPBOX_CLIENT_ID=your_dropbox_client_id
DROPBOX_CLIENT_SECRET=your_dropbox_client_secret
DROPBOX_REFRESH_TOKEN=your_dropbox_refresh_token

# Note: If both access token and refresh token are provided, refresh token will be used

# =============================================================================
# GOOGLE DRIVE CONFIGURATION
# =============================================================================

# Option 1: Service Account (Recommended - no token expiration issues)
# Create service account at: https://console.cloud.google.com/iam-admin/serviceaccounts
# Download JSON key file or paste the JSON content directly

# Path to service account JSON key file
# GOOGLE_SERVICE_ACCOUNT_KEY_PATH=/path/to/service-account-key.json

# OR paste the entire JSON content (alternative to file path)
# GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}

# Name of shared folder to use as root (service account needs access to this folder)
# Default: "KADI" - create this folder and share it with your service account email
GOOGLE_SHARED_FOLDER_NAME=KADI

# Option 2: OAuth 2.0 (Alternative - requires periodic token refresh)
# Tokens obtained through OAuth flow using setup-google-drive-oauth.js
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret
# GOOGLE_REFRESH_TOKEN=your_google_refresh_token

# =============================================================================
# BOX CONFIGURATION
# =============================================================================

# Box OAuth credentials
# Create app at: https://app.box.com/developers/console
BOX_CLIENT_ID=your_box_client_id
BOX_CLIENT_SECRET=your_box_client_secret

# Box tokens (obtained through OAuth setup)
# BOX_ACCESS_TOKEN=your_box_access_token
BOX_REFRESH_TOKEN=your_box_refresh_token

# Note: Box tokens typically last 1 hour. Refresh tokens are used to get new access tokens.

# =============================================================================
# USAGE NOTES
# =============================================================================

# 1. You only need to configure the services you plan to use
# 2. For production use, OAuth with refresh tokens is recommended
# 3. Never commit the .env file with real credentials to version control
# 4. See README.md for detailed setup instructions for each service
