{
  "name": "ability-file-cloud",
  "type": "ability",
  "version": "0.2.0",
  "description": "Cloud file operations - Dropbox, Google Drive, Box",
  "entrypoint": "dist/index.js",
  "abilities": {
    "secret-ability": "*"
  },
  "brokers": {
    "remote": "wss://broker.dadavidtseng.com/kadi"
  },
  "scripts": {
    "preflight": "node --version",
    "setup": "npm install && npm run build",
    "build": "npx tsc",
    "start": "node dist/index.js",
    "dev": "npx tsx index.ts",
    "serve": "npx tsx index.ts stdio",
    "serve:broker": "npx tsx index.ts broker",
    "clean": "rm -rf node_modules abilities agent-lock.json package-lock.json dist"
  }
}
