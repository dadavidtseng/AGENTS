{
  "name": "mcp-server-quest",
  "version": "0.1.0",
  "scripts": {
    "start": "node dist/mcp-server.js"
  },
  "build": {
    "default": {
      "from": "node:20-alpine",
      "cli": "latest",
      "run": [
        "npm ci --include=dev",
        "npx tsc",
        "npm prune --omit=dev"
      ],
      "env": {
        "NODE_ENV": "production"
      }
    }
  },
  "deploy": {
    "akash-mainnet": {
      "target": "akash",
      "network": "mainnet",
      "engine": "podman",
      "services": {
        "app": {
          "image": "mcp-server-quest:0.1.0",
          "expose": [
            { "port": 3100, "as": 3100, "to": [{ "global": true }] }
          ],
          "env": [
            "MCP_TRANSPORT_TYPE=http",
            "MCP_PORT=3100",
            "NODE_ENV=production"
          ],
          "resources": {
            "cpu": 0.5,
            "memory": "512Mi",
            "ephemeralStorage": "512Mi"
          }
        }
      }
    }
  }
}
