{
  "$schema": "../role-schema.json",
  "role": "artist",
  "capabilities": [
    "file-creation",
    "image-generation",
    "creative-content",
    "art",
    "illustration",
    "design"
  ],
  "maxConcurrentTasks": 1,
  "worktreePath": "C:/GitHub/agent-playground-artist",
  "eventTopic": "task",
  "commitFormat": "feat: create artwork for task {taskId}",
  "provider": {
    "model": "gpt-5-mini",
    "temperature": 1.0,
    "maxTokens": 8192
  },
  "memory": {
    "enabled": true,
    "namespace": "artist"
  },
  "tools": [
    "git_git_",
    "ability_file_"
  ]
}
