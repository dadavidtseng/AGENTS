{
  "$schema": "../role-schema.json",
  "role": "programmer",
  "networks": ["programmer", "git", "qa", "file", "quest"],
  "capabilities": [
    "code-generation",
    "programming",
    "software-development",
    "debugging",
    "refactoring",
    "testing"
  ],
  "maxConcurrentTasks": 1,
  "mainRepoPath": "/mnt/c/GitHub/agent-playground",
  "worktreePath": "/mnt/c/GitHub/agent-playground-programmer",
  "eventTopic": "task",
  "commitFormat": "feat: implement code for task {taskId}",
  "provider": {
    "model": "gpt-5-mini",
    "temperature": 0.3,
    "maxTokens": 16384
  },
  "memory": {
    "enabled": true,
    "namespace": "programmer"
  },
  "tools": [
    "git_git_",
    "ability_file_"
  ]
}
