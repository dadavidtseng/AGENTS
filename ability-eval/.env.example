# KĀDI Configuration for ability-eval
# Copy this file to .env and configure for your environment

# Transport mode: native, stdio, or broker
KADI_MODE=stdio

# Broker WebSocket URL (required when KADI_MODE=broker)
# KADI_BROKER_URL=ws://localhost:8080/kadi

# Network scope for this ability
# KADI_NETWORK=eval

# Model Manager gateway
# MODEL_MANAGER_BASE_URL=https://your-model-manager-url.com/
# MODEL_MANAGER_API_KEY=kadi_...

# Evaluation model
# EVAL_MODEL=gpt-4o

# Max tokens for LLM response
# EVAL_MAX_TOKENS=4096

# Request timeout (ms)
# EVAL_TIMEOUT_MS=120000

# Optional: Enable debug logging
# KADI_DEBUG=true
