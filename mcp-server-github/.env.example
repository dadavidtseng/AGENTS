# GitHub MCP Server - Environment Variables

# Required: GitHub Personal Access Token
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: GitHub API base URL (default: https://api.github.com)
# GITHUB_API_URL=https://api.github.com

# Optional: GitHub Enterprise host
# GITHUB_HOST=https://github.example.com

# MCP Transport Configuration
# MCP_TRANSPORT_TYPE=stdio    # stdio (default) or http
# MCP_HTTP_PORT=3016
# MCP_HTTP_HOST=127.0.0.1
# MCP_LOG_LEVEL=info          # debug, info, warn, error
