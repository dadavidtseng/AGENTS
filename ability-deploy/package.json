{
  "name": "ability-deploy",
  "version": "0.2.0",
  "description": "Unified deployment ability — Akash Network, local Docker/Podman, and container registry management",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./akash": {
      "types": "./dist/targets/akash/index.d.ts",
      "import": "./dist/targets/akash/index.js"
    },
    "./local": {
      "types": "./dist/targets/local/index.d.ts",
      "import": "./dist/targets/local/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js"
    },
    "./errors": {
      "types": "./dist/errors/index.d.ts",
      "import": "./dist/errors/index.js"
    },
    "./registry": {
      "types": "./dist/utils/registry/index.d.ts",
      "import": "./dist/utils/registry/index.js"
    }
  },
  "scripts": {
    "start": "node index.js",
    "build": "tsc && cp -r src/registry dist/registry",
    "build:watch": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist",
    "format": "prettier --write .",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "kadi",
    "deployment",
    "akash",
    "docker",
    "kubernetes",
    "orchestration",
    "infrastructure"
  ],
  "author": "Yu-Wei Tseng",
  "license": "Apache License 2.0",
  "files": [
    "dist/",
    "docs/",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@kadi.build/core": "^0.9.0",
    "ability-file-remote": "file:../ability-file-remote",
    "@akashnetwork/akash-api": "^1.4.0",
    "@akashnetwork/chain-sdk": "1.0.0-alpha.18",
    "@cosmjs/amino": "^0.36.1",
    "@cosmjs/encoding": "^0.36.1",
    "@cosmjs/proto-signing": "^0.36.1",
    "@cosmjs/stargate": "^0.36.1",
    "chalk": "^5.3.0",
    "fs-extra": "^11.2.0",
    "@keplr-wallet/wc-client": "^0.12.243",
    "@keplr-wallet/wc-qrcode-modal": "^0.12.247",
    "@types/ws": "^8.18.1",
    "@walletconnect/sign-client": "^2.21.3",
    "axios": "^1.7.7",
    "debug": "^4.3.7",
    "dockerode": "^4.0.7",
    "dotenv": "^16.5.0",
    "js-yaml": "^4.1.0",
    "long": "^5.2.3",
    "strip-ansi": "^7.1.2",
    "ws": "^8.18.3",
    "yaml": "^2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/debug": "^4.1.12",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.38.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.6.2",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
