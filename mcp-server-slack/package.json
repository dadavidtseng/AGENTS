{
  "name": "mcp-slack-server",
  "version": "1.0.0",
  "description": "MCP Server for sending Slack messages (for Claude Desktop and KADI agents)",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit"
