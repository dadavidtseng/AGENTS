{
  "name": "mcp-server-github",
  "version": "0.1.0",
  "scripts": {
    "start": "node dist/index.js"
  },
  "build": {
    "default": {
      "from": "node:20-alpine",
      "cli": "latest",
      "run": [
        "npm install -g bun",
        "npm ci --include=dev",
        "bun build ./src/index.ts --outdir ./dist --target node --external pino --external pino-pretty --external @octokit/rest",
        "npm prune --omit=dev"
      ],
      "env": {
        "NODE_ENV": "production"
      }
    }
  }
}
