{
  "name": "ability-backup",
  "type": "ability",
  "version": "0.1.3",
  "description": "KADI ability — backup/restore orchestrator for ArcadeDB via broker tools. Supports co-located and distributed topologies.",
  "entrypoint": "dist/index.js",
  "abilities": {
    "secret-ability": "*"
  },
  "brokers": {
    "remote": "wss://broker.dadavidtseng.com/kadi"
  },
  "scripts": {
    "preflight": "node --version",
    "setup": "npm install && npm run build",
    "build": "npx tsc",
    "start": "node dist/index.js",
    "dev": "npx tsx src/index.ts",
    "clean": "rm -rf node_modules abilities agent-lock.json package-lock.json dist"
  },
  "build": {
    "default": {
      "image": "ability-backup:0.1.3",
      "from": "node:22-alpine",
      "platform": "linux/amd64",
      "cli": "latest",
      "run": [
        "npm ci --include=dev",
        "npm run build",
        "kadi install kadi-install",
        "kadi install kadi-run",
        "kadi install kadi-secret",
        "kadi install",
        "npm prune --omit=dev"
      ],
      "cmd": ["sh", "-c", "kadi run start"]
    }
  },
  "deploy": {
    "local": {
      "target": "local",
      "engine": "docker",
      "services": {
        "backup": {
          "image": "ability-backup:0.1.3",
          "command": ["sh", "-c", "kadi secret receive --vault backup && kadi run start"],
          "env": ["NODE_ENV=production", "DASHBOARD_PORT=80"],
          "expose": [
            { "port": 80, "as": 8090 }
          ]
        }
      },
      "secrets": {
        "vaults": [
          { "vault": "tunnel", "required": ["KADI_TUNNEL_TOKEN"] },
          { "vault": "backup", "required": ["DASHBOARD_USERNAME", "DASHBOARD_PASSWORD"] }
        ],
        "delivery": "broker"
      }
    },
    "production": {
      "target": "akash",
      "network": "mainnet",
      "deposit": "10",
      "blacklist": [
        "akash1sevd2ymtty3dpq9ycxgkhuzzk4fe6mchqdwd4e",
        "akash14w36hwrtuqqa3j92fa8ctcxlhjgvr3a0zpp7cj",
        "akash1sjwuwre4qprcaa34f6324yz7m8nn0awvc75gp5"
      ],
      "engine": "podman",
      "services": {
        "backup": {
          "image": "ability-backup:0.1.3",
          "command": ["sh", "-c", "kadi secret receive --vault backup && kadi run start"],
          "expose": [
            { "port": 80, "as": 80, "to": [{ "global": true }] }
          ],
          "resources": {
            "cpu": 0.5,
            "memory": "512Mi",
            "ephemeralStorage": "1Gi"
          },
          "pricing": { "amount": "500", "denom": "uact" }
        }
      },
      "secrets": {
        "vaults": [
          { "vault": "tunnel", "required": ["KADI_TUNNEL_TOKEN"] },
          { "vault": "backup", "required": ["DASHBOARD_USERNAME", "DASHBOARD_PASSWORD"] }
        ],
        "delivery": "broker"
      }
    }
  }
}
