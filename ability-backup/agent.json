{
  "name": "ability-backup",
  "type": "ability",
  "version": "0.1.0",
  "description": "KADI ability — backup/restore orchestrator for ArcadeDB via broker tools. Supports co-located and distributed topologies.",
  "entrypoint": "dist/index.js",
  "abilities": {
    "secret-ability": "^0.9.4"
  },
  "brokers": {
    "local": "ws://localhost:8080/kadi",
    "remote": "wss://broker.dadavidtseng.com/kadi"
  },
  "scripts": {
    "preflight": "node --version",
    "setup": "npm install && npm run build",
    "build": "npx tsc",
    "start": "node dist/index.js",
    "dev": "npx tsx src/index.ts",
    "clean": "rm -rf node_modules abilities agent-lock.json package-lock.json dist"
  },
  "deploy": {
    "local": {
      "target": "local",
      "engine": "docker",
      "services": {
        "backup": {
          "image": "ability-backup:latest",
          "command": ["sh", "-c", "kadi secret receive --vault backup && kadi run"],
          "env": ["NODE_ENV=production", "DASHBOARD_PORT=80"],
          "expose": [
            { "port": 80, "as": 8090 }
          ]
        }
      },
      "secrets": {
        "vault": "backup",
        "required": ["KADI_TUNNEL_TOKEN", "DASHBOARD_USERNAME", "DASHBOARD_PASSWORD"],
        "delivery": "broker"
      }
    }
  }
}
