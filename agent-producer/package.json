{
  "name": "agent-producer",
  "version": "0.3.2",
  "description": "Agent orchestrator - KĀDI agent for coordinating worker agents via KĀDI protocol",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest"
  },
  "keywords": [
    "kadi",
    "agent",
    "mcp",
    "orchestrator",
    "multi-agent",
    "typescript"
  ],
  "author": "Yu-Wei Tseng",
  "license": "Apache License 2.0",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@kadi.build/core": "latest",
    "@modelcontextprotocol/sdk": "1.26.0",
    "agents-library": "latest",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^8.57.1",
    "patch-package": "^8.0.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
