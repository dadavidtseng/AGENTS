{
  "name": "agent-producer",
  "version": "0.1.0",
  "scripts": {
    "preflight": "node -e \"const fs=require('fs');if(!fs.existsSync('node_modules')){console.error('Dependencies not installed. Run: npm install');process.exit(1)}console.log('✓ Dependencies OK')\"",
    "setup": "npx tsc",
    "start": "node dist/index.js",
    "dev": "npx tsx watch src/index.ts",
    "build": "npx tsc",
    "type-check": "npx tsc --noEmit",
    "lint": "npx eslint src --ext .ts",
    "test": "npx vitest"
  },
  "build": {
    "default": {
      "from": "node:20-alpine",
      "cli": "latest",
      "run": [
        "npm ci --include=dev",
        "npx tsc",
        "npm prune --omit=dev"
      ],
      "env": {
        "NODE_ENV": "production"
      }
    }
  },
  "deploy": {
    "akash-mainnet": {
      "target": "akash",
      "network": "mainnet",
      "engine": "podman",
      "services": {
        "app": {
          "image": "agent-producer:0.1.0",
          "expose": [
            {
              "port": 3000,
              "as": 3000,
              "to": [
                {
                  "global": true
                }
              ]
            }
          ],
          "env": [
            "KADI_BROKER_URL=ws://localhost:8080/kadi",
            "KADI_BROKER_URL_2=ws://kadi.build:8080/kadi",
            "NODE_ENV=production"
          ],
          "resources": {
            "cpu": 0.5,
            "memory": "512Mi",
            "ephemeralStorage": "1Gi"
          }
        }
      },
      "secrets": {
        "vault": "agent-producer",
        "required": [
          "ANTHROPIC_API_KEY",
          "MODEL_MANAGER_API_KEY"
        ],
        "delivery": "broker"
      }
    }
  },
  "abilities": {
    "secret-ability": "^0.9.4"
  },
  "brokers": {
    "default": "ws://localhost:8080/kadi"
  }
}
