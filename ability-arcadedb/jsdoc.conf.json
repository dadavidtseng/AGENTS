{
  "source": {
    "include": [
      "./arcade-admin.js",
      "./lib/",
      "./README.md"
    ],
    "includePattern": "\\.(js|mjs)$",
    "exclude": [
      "./node_modules/",
      "./doc/",
      "./wip/",
      "./test-runner.js"
    ]
  },
  "opts": {
    "destination": "./doc/",
    "recurse": true,
    "readme": "./README.md"
  },
  "plugins": [
    "plugins/markdown"
  ],
  "templates": {
    "cleverLinks": false,
    "monospaceLinks": false
  }
}