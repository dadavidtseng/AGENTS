{
  "name": "arcadedb-ability",
  "version": "0.1.1",
  "description": "KADI ability wrapping ArcadeDB 26.2.1 as 17 broker-callable tools (includes backup/restore with distributed file transfer)",
  "type": "ability",
  "entrypoint": "dist/index.js",
  "abilities": {
    "secret-ability": "^0.9.4"
  },
  "brokers": {
    "local": "ws://localhost:8080/kadi",
    "remote": "wss://broker.dadavidtseng.info/kadi"
  },
  "scripts": {
    "preflight": "echo 'Setting up ArcadeDB ability...'",
    "setup": "npm install && npm run build",
    "start": "node dist/index.js broker"
  },
  "build": {
    "default": {
      "image": "arcadedb-ability:0.1.4",
      "stages": [
        {
          "name": "arcadedb-src",
          "from": "arcadedata/arcadedb:26.2.1"
        }
      ],
      "from": "node:22-alpine",
      "platform": "linux/amd64",
      "cli": "latest",
      "copy": [
        { "from": "arcadedb-src", "src": "/opt/java/openjdk", "dest": "/opt/java/openjdk" },
        { "from": "arcadedb-src", "src": "/home/arcadedb", "dest": "/home/arcadedb" }
      ],
      "env": {
        "KADI_DEPLOY_MODE": "container",
        "ARCADE_HOST": "arcadedb.kadi.build",
        "ARCADE_PORT": "80",
        "ARCADEDB_HOME": "/home/arcadedb",
        "JAVA_HOME": "/opt/java/openjdk",
        "PATH": "/opt/java/openjdk/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
      },
      "run": [
        "apk add --no-cache curl",
        "npm ci",
        "npm run build",
        "kadi install kadi-install",
        "kadi install kadi-run",
        "kadi install kadi-secret",
        "kadi install",
        "chmod +x scripts/start-arcadedb.sh",
        "sed -i 's/\\r$//' scripts/start-arcadedb.sh"
      ],
      "cmd": ["sh", "-c", ". ./scripts/start-arcadedb.sh && kadi run start"]
    }
  },
  "deploy": {
    "local": {
      "target": "local",
      "engine": "docker",
      "services": {
        "agent": {
          "image": "arcadedb-ability:0.1.4",
          "command": [
            "sh",
            "-c",
            "kadi secret receive --vault arcadedb && . ./scripts/start-arcadedb.sh && kadi run start"
          ],
          "expose": [
            { "port": 2480, "as": 2480 },
            { "port": 9090, "as": 9090 }
          ]
        }
      },
      "secrets": {
        "vault": "arcadedb",
        "required": ["ARCADE_USERNAME", "ARCADE_PASSWORD", "KADI_TUNNEL_TOKEN"],
        "delivery": "broker"
      }
    },
    "production": {
      "target": "akash",
      "network": "mainnet",
      "deposit": "10",
      "depositDenom": "uact",
      "services": {
        "agent": {
          "image": "docker.io/dadavidtseng/arcadedb-ability:0.1.4",
          "command": [
            "sh",
            "-c",
            ". ./scripts/start-arcadedb.sh && kadi run start"
          ],
          "env": [
            "BROKER_URL=wss://broker.dadavidtseng.info/kadi",
            "ARCADE_USERNAME=root",
            "ARCADE_PASSWORD=playwithdata"
          ],
          "expose": [
            { "port": 2480, "as": 80, "to": [{ "global": true }] }
          ],
          "resources": {
            "cpu": 1,
            "memory": "1Gi",
            "ephemeralStorage": "2Gi"
          },
          "pricing": {
            "amount": "500",
            "denom": "uact"
          }
        }
      },
      "secrets": {
        "vault": "arcadedb",
        "required": ["ARCADE_USERNAME", "ARCADE_PASSWORD", "KADI_TUNNEL_TOKEN"],
        "delivery": "broker"
      }
    }
  }
}
