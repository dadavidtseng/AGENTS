{
  "name": "agent-quest",
  "type": "agent",
  "version": "0.3.9",
  "entrypoint": "dist/index.js",
  "scripts": {
    "preflight": "node -e \"const fs=require('fs');if(!fs.existsSync('node_modules')){console.error('Dependencies not installed. Run: npm install');process.exit(1)}console.log('✓ Dependencies OK')\"",
    "setup": "npm run install:all && npm run build",
    "dev": "npx concurrently --raw --kill-others-on-fail \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "cd client && npx vite",
    "dev:server": "cd server && npx tsx watch src/index.ts",
    "build": "npm run build:client && npm run build:server",
    "build:client": "npm run build --prefix client",
    "build:server": "npm run build --prefix server",
    "start": "node server/dist/index.js",
    "install:all": "npm install && npm install --prefix client && npm install --prefix server",
    "lint": "npm run lint --prefix client && npm run lint --prefix server",
    "test": "npm run test --prefix client && npm run test --prefix server",
    "type-check": "npx tsc --noEmit --prefix client && npx tsc --noEmit --prefix server"
  },
  "build": {
    "default": {
      "from": "node:20-alpine",
      "cli": "latest",
      "run": [
        "NODE_ENV=development npm run install:all",
        "kadi install kadi-secret",
        "mkdir -p /app/abilities && cp -a /opt/kadi/abilities/secret-ability@* /app/abilities/",
        "npm run build",
        "npm prune --omit=dev --prefix server",
        "rm -rf client/node_modules"
      ],
      "env": {
        "NODE_ENV": "production"
      }
    }
  },
  "deploy": {
    "akash": {
      "target": "akash",
      "network": "mainnet",
      "deposit": "10",
      "blacklist": [
        "akash1sevd2ymtty3dpq9ycxgkhuzzk4fe6mchqdwd4e",
        "akash14w36hwrtuqqa3j92fa8ctcxlhjgvr3a0zpp7cj"
      ],
      "engine": "podman",
      "services": {
        "app": {
          "image": "agent-quest:0.3.9",
          "command": [
            "sh",
            "-c",
            "kadi secret receive --vault observer --vault arcadedb && kadi run start"
          ],
          "expose": [
            {
              "port": 8888,
              "as": 8888,
              "to": [
                {
                  "global": true
                }
              ]
            }
          ],
          "env": [
            "NODE_ENV=production",
            "ARCADE_HOST=arcadedb.dadavidtseng.com",
            "ARCADE_PORT=443"
          ],
          "resources": {
            "cpu": 0.5,
            "memory": "512Mi",
            "ephemeralStorage": "1Gi"
          },
          "pricing": {
            "amount": "500",
            "denom": "uact"
          }
        }
      },
      "secrets": {
        "vaults": [
          {
            "vault": "observer",
            "required": [
              "OBSERVER_PASSWORD"
            ]
          },
          {
            "vault": "arcadedb",
            "required": [
              "ARCADE_USERNAME",
              "ARCADE_PASSWORD"
            ]
          }
        ],
        "delivery": "broker"
      }
    }
  },
  "brokers": {
    "remote": "wss://broker.dadavidtseng.com/kadi"
  },
  "networks": [
    "quest",
    "global"
  ],
  "abilities": {
    "secret-ability": "*",
    "ability-log": "^0.1.2"
  }
}
