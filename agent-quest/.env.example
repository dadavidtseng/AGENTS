# Server
PORT=8888
NODE_ENV=development

# CORS — comma-separated origins for multi-deployment support
# CLIENT_ORIGIN is kept for backward compatibility; CORS_ORIGINS takes precedence.
CORS_ORIGINS=http://localhost:5173
# CLIENT_ORIGIN=http://localhost:5173

# KĀDI Broker
KADI_BROKER_URL=ws://localhost:8080/mcp
# WS_STDIO_BRIDGE_PATH=C:\\GitHub\\kadi\\kadi-broker\\src\\utils\\ws-stdio-bridge.ts

# Quest Data — path to mcp-server-quest .quest-data directory for file watching
# QUEST_DATA_PATH=C:/GitHub/mcp-server-quest/.quest-data
