# Server
PORT=8888
NODE_ENV=development

# CORS — comma-separated origins for multi-deployment support
# CLIENT_ORIGIN is kept for backward compatibility; CORS_ORIGINS takes precedence.
CORS_ORIGINS=http://localhost:5173
# CLIENT_ORIGIN=http://localhost:5173

# KĀDI Broker
# Primary broker (default network: quest)
KADI_BROKER_URL=ws://localhost:8080/kadi

# Additional brokers (optional) — for multi-broker network topology
# Pattern: KADI_BROKER_URL_<NAME> where <NAME> becomes the broker identifier
# Example: Connect to a remote producer broker for distributed orchestration
# KADI_BROKER_URL_PRODUCER=ws://remote-host:8080/kadi
# KADI_BROKER_URL_REMOTE=ws://another-host:8080/kadi

# WS_STDIO_BRIDGE_PATH=C:\\GitHub\\kadi\\kadi-broker\\src\\utils\\ws-stdio-bridge.ts

# Observer SSE — password for broker's /api/admin/observer endpoint (optional)
# OBSERVER_PASSWORD=

# Quest Data — path to mcp-server-quest .quest-data directory for file watching
# QUEST_DATA_PATH=C:/GitHub/mcp-server-quest/.quest-data

# GitHub Webhook — secret for verifying webhook signatures (HMAC-SHA256)
# Set this to the same secret configured in your GitHub repo webhook settings.
# If empty, signature verification is skipped (dev mode only).
# GITHUB_WEBHOOK_SECRET=
