{
  "site": {
    "title": "AGENTS Documentation",
    "tagline": "Multi-Agent Orchestration Platform",
    "domain": "localhost",
    "baseUrl": "/",
    "port": 3333
  },
  "repos": {
    "agents-core": {
      "path": "..",
      "description": "AGENTS monorepo root — architecture, concepts, deployment guides",
      "type": "kadi-monorepo",
      "crawl": ["Docs/**/*.md", "README.md", "KADI-ARCHITECTURE-CONCEPTS.md"]
    },
    "agents-library": {
      "path": "../agents-library",
      "description": "Shared agent utilities, factories, and base classes",
      "type": "kadi-package",
      "crawl": ["README.md"],
      "generateApi": true,
      "entryPoints": ["src/index.ts"]
    },
    "agent-producer": {
      "path": "../agent-producer",
      "description": "Orchestrator agent — decomposes quests into tasks",
      "type": "kadi-agent",
      "crawl": ["README.md", "agent.json"]
    },
    "agent-worker": {
      "path": "../agent-worker",
      "description": "Programmer agent — executes coding tasks",
      "type": "kadi-agent",
      "crawl": ["README.md", "agent.json"]
    },
    "agent-lead": {
      "path": "../agent-lead",
      "description": "Tech lead agent — reviews and assigns tasks",
      "type": "kadi-agent",
      "crawl": ["README.md", "agent.json"]
    },
    "agent-qa": {
      "path": "../agent-qa",
      "description": "QA agent — verifies task completion",
      "type": "kadi-agent",
      "crawl": ["README.md", "agent.json"]
    },
    "agent-chatbot": {
      "path": "../agent-chatbot",
      "description": "Chat platform agent — Discord/Slack integration",
      "type": "kadi-agent",
      "crawl": ["README.md", "agent.json"]
    },
    "agent-quest": {
      "path": "../agent-quest",
      "description": "Quest management UI and server",
      "type": "kadi-agent",
      "crawl": ["README.md", "agent.json"]
    },
    "mcp-server-quest": {
      "path": "../mcp-server-quest",
      "description": "Quest protocol MCP server",
      "type": "kadi-package",
      "crawl": ["README.md", "agent.json"]
    },
    "mcp-server-git": {
      "path": "../mcp-server-git",
      "description": "Git operations MCP server",
      "type": "kadi-package",
      "crawl": ["README.md", "agent.json"]
    },
    "ability-memory": {
      "path": "../ability-memory",
      "description": "Memory domain layer — task memory, feedback, role-based context",
      "type": "kadi-ability",
      "crawl": ["README.md", "agent.json"]
    },
    "ability-graph": {
      "path": "../ability-graph",
      "description": "Graph engine — N-signal hybrid search, ArcadeDB integration",
      "type": "kadi-ability",
      "crawl": ["README.md", "agent.json"]
    },
    "ability-search": {
      "path": "../ability-search",
      "description": "Search engine — chunking, embedding, hybrid text search",
      "type": "kadi-ability",
      "crawl": ["README.md", "agent.json"]
    },
    "ability-arcadedb": {
      "path": "../ability-arcadedb",
      "description": "ArcadeDB wrapper — database admin, backup/restore",
      "type": "kadi-ability",
      "crawl": ["README.md", "agent.json"]
    },
    "ability-secret": {
      "path": "../ability-secret",
      "description": "Vault-based secret management",
      "type": "kadi-ability",
      "crawl": ["README.md", "agent.json"]
    },
    "ability-eval": {
      "path": "../ability-eval",
      "description": "Code evaluation ability",
      "type": "kadi-ability",
      "crawl": ["README.md", "agent.json"]
    },
    "ability-vision": {
      "path": "../ability-vision",
      "description": "Vision/screenshot ability",
      "type": "kadi-ability",
      "crawl": ["README.md", "agent.json"]
    },
    "ability-file-local": {
      "path": "../ability-file-local",
      "description": "Local filesystem operations",
      "type": "kadi-ability",
      "crawl": ["README.md", "agent.json"]
    },
    "ability-file-remote": {
      "path": "../ability-file-remote",
      "description": "Remote filesystem operations",
      "type": "kadi-ability",
      "crawl": ["README.md", "agent.json"]
    },
    "ability-file-cloud": {
      "path": "../ability-file-cloud",
      "description": "Cloud storage operations",
      "type": "kadi-ability",
      "crawl": ["README.md", "agent.json"]
    },
    "ability-docs-memory": {
      "path": "../ability-docs-memory",
      "description": "Documentation search engine — 4-signal hybrid recall",
      "type": "kadi-ability",
      "crawl": ["README.md", "agent.json"]
    },
    "ability-backup": {
      "path": "../ability-backup",
      "description": "Backup and restore ability",
      "type": "kadi-ability",
      "crawl": ["README.md", "agent.json"]
    },
    "ability-deploy": {
      "path": "../ability-deploy",
      "description": "Deployment ability — Akash, local, DigitalOcean targets",
      "type": "kadi-ability",
      "crawl": ["README.md", "agent.json"]
    },
    "ability-tunnel": {
      "path": "../ability-tunnel",
      "description": "Network tunnel ability",
      "type": "kadi-ability",
      "crawl": ["README.md", "agent.json"]
    },
    "ability-voice": {
      "path": "../ability-voice",
      "description": "Voice/audio ability",
      "type": "kadi-ability",
      "crawl": ["README.md", "agent.json"]
    },
    "agent-docs": {
      "path": "../agent-docs",
      "description": "Documentation engine and Docusaurus site for AGENTS",
      "type": "kadi-agent",
      "crawl": ["README.md", "agent.json"]
    },
    "agent-expert": {
      "path": "../agent-expert",
      "description": "Expert agent — answers questions about AGENTS using docs search",
      "type": "kadi-agent",
      "crawl": ["README.md", "agent.json"]
    },
    "agent-builder": {
      "path": "../agent-builder",
      "description": "Builder agent — scaffolds new agents and abilities",
      "type": "kadi-agent",
      "crawl": ["README.md", "agent.json"]
    },
    "agent-shadow-worker": {
      "path": "../agent-shadow-worker",
      "description": "Shadow worker agent — parallel task execution",
      "type": "kadi-agent",
      "crawl": ["README.md", "agent.json"]
    },
    "mcp-server-github": {
      "path": "../mcp-server-github",
      "description": "GitHub operations MCP server",
      "type": "kadi-package",
      "crawl": ["README.md", "agent.json"]
    },
    "template-agent-python": {
      "path": "../template-agent-python",
      "description": "Python agent template",
      "type": "kadi-package",
      "crawl": ["README.md", "agent.json"]
    },
    "template-agent-typescript": {
      "path": "../template-agent-typescript",
      "description": "TypeScript agent template",
      "type": "kadi-package",
      "crawl": ["README.md", "agent.json"]
    },
    "engine": {
      "path": "../../Engine",
      "description": "Daemon Engine — C++20 game engine with DirectX 11, V8 scripting",
      "type": "cpp-engine",
      "crawl": ["README.md", "CLAUDE.md", "Docs/**/*.md"]
    },
    "daemon-agent": {
      "path": "../../DaemonAgent",
      "description": "DaemonAgent — dual-language game project (C++20 + TypeScript)",
      "type": "cpp-game",
      "crawl": ["CLAUDE.md", "Docs/**/*.md", "openspec/**/*.md"]
    }
  },
  "output": {
    "buildDir": "build",
    "deployTarget": "build"
  },
  "agent": {
    "name": "agent-docs",
    "version": "0.1.2",
    "description": "Documentation engine for the AGENTS ecosystem",
    "defaultBroker": "remote",
    "brokers": {
      "remote": "wss://broker.dadavidtseng.com/kadi"
    },
    "networks": ["global"],
    "abilities": {
      "secret-ability": "*",
      "ability-docs-memory": "^0.0.1"
    },
    "secrets": {
      "vault": "model-manager",
      "required": ["MODEL_MANAGER_API_KEY", "MODEL_MANAGER_BASE_URL"],
      "optional": []
    }
  }
}
