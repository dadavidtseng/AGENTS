{
  "name": "agent-docs",
  "version": "1.0.0",
  "type": "module",
  "description": "Documentation engine and KADI agent for the AGENTS ecosystem",
  "main": "dist/agent.js",
  "scripts": {
    "build:ts": "tsc",
    "start": "node dist/agent.js broker",
    "dev": "astro dev --port 3333",
    "dev:agent": "npx tsx src/agent.ts broker",
    "sync": "npx tsx scripts/sync-cli.ts",
    "build": "npm run sync && astro build",
    "serve": "astro preview --port 3333",
    "clean": "rm -rf dist .astro",
    "agent": "npx tsx src/agent.ts broker",
    "readme-gen": "npx tsx scripts/readme-gen-cli.ts",
    "readme-gen:llm": "npx tsx scripts/readme-gen-llm.ts"
  },
  "dependencies": {
    "@astrojs/react": "^4.2.0",
    "@astrojs/starlight": "^0.34.0",
    "@kadi.build/core": "^0.11.2",
    "astro": "^5.7.0",
    "zod": "^3.23.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.33.0",
    "tailwindcss": "^3.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18.0"
  }
}
