# KĀDI Broker
KADI_MODE=broker
KADI_BROKER_URL=ws://localhost:8080/kadi
KADI_NETWORK=infra

# Default tunnel settings
TUNNEL_DEFAULT_PORT=3000
TUNNEL_DEFAULT_MODE=auto
TUNNEL_TIMEOUT_MS=0
TUNNEL_MAX_CONCURRENT=10

# kadi-tunnel (KĀDI cloud infrastructure)
KADI_TUNNEL_TOKEN=
KADI_TUNNEL_SERVER=broker.kadi.build
KADI_TUNNEL_DOMAIN=tunnel.kadi.build
KADI_TUNNEL_SSH_PORT=2200
KADI_TUNNEL_SSH_USER=v0
KADI_TUNNEL_FRPC_PORT=7000
KADI_TUNNEL_TRANSPORT=wss
KADI_TUNNEL_WSS_HOST=tunnel-control.kadi.build

# Optional: self-hosted kadi-tunnel control API
KADI_TUNNEL_CONTROL_API_URL=
KADI_TUNNEL_AGENT_ID=default-agent
KADI_TUNNEL_REQUEST_TIMEOUT_MS=30000

# Public provider tokens
NGROK_AUTH_TOKEN=
PINGGY_TOKEN=

# SSH reverse tunnel settings (generic, not kadi)
SSH_TUNNEL_HOST=
SSH_TUNNEL_PORT=22
SSH_TUNNEL_USER=tunnel
SSH_TUNNEL_KEY_PATH=

# frpc settings (generic, not kadi)
FRPC_SERVER_ADDR=
FRPC_SERVER_PORT=7000
FRPC_TOKEN=

# Reconnection
TUNNEL_AUTO_RECONNECT=true
TUNNEL_MAX_RECONNECT_ATTEMPTS=10
TUNNEL_RECONNECT_DELAY_MS=1000
