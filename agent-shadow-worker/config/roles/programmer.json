{
  "$schema": "../shadow-role-schema.json",
  "role": "programmer",
  "mainRepoPath": "/mnt/c/GitHub/agent-playground",
  "workerWorktreePath": "/mnt/c/GitHub/agent-playground-programmer",
  "shadowWorktreePath": "/mnt/c/GitHub/shadow-agent-playground-programmer",
  "workerBranch": "agent-playground-programmer",
  "shadowBranch": "shadow-agent-playground-programmer",
  "monitoringInterval": 5000,
  "debounceMs": 1000,
  "provider": {
    "model": "gpt-5-mini",
    "temperature": 0.3,
    "maxTokens": 4096
  },
  "memory": {
    "enabled": false,
    "namespace": "shadow-programmer"
  }
}
