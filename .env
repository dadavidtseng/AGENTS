# Deploy Ability Configuration
# This is your active configuration file

# =============================================================================
# KADI Configuration
# =============================================================================

KADI_MODE=broker
KADI_BROKER_URL=ws://localhost:8080/kadi
KADI_NETWORK=deploy

# =============================================================================
# AKASH NETWORK CONFIGURATION
# =============================================================================

# Configure your Akash credentials here
# AKASH_RPC_ENDPOINT=
# AKASH_API_ENDPOINT=
# AKASH_WALLET_MNEMONIC=

# =============================================================================
# LOCAL DOCKER CONFIGURATION
# =============================================================================

LOCAL_ENGINE=docker
LOCAL_DEFAULT_PROFILE=local-dev

# =============================================================================
# DEPLOYMENT DEFAULTS
# =============================================================================

DEPLOY_MONITOR_READINESS=true
DEPLOY_DRY_RUN=false
LOG_LEVEL=info
