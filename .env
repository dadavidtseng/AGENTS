# KADI Configuration for ability-voice
# Copy this file to .env and configure for your environment

# Transport mode: native, stdio, or broker
KADI_MODE=broker

# Broker WebSocket URL (required when KADI_MODE=broker)
KADI_BROKER_URL=ws://localhost:8080/kadi

# Network scope for this ability
KADI_NETWORK=voice

# Whisper model: tiny.en, base.en, small.en, medium.en, large-v3
WHISPER_MODEL=tiny.en

# Piper TTS voice model
PIPER_VOICE=en_US-lessac-medium

# Wake word configuration
KADI_WAKE_WORD=hey katie
# KADI_WAKE_WORD_ALT=hey katie,hey kady,hey kv,...

# Voice Activity Detection aggressiveness (0-3, higher = more aggressive)
KADI_VAD_AGGRESSIVENESS=2

# Silence timeout before ending recording (ms)
KADI_SILENCE_TIMEOUT_MS=1500

# Max recording duration (seconds)
KADI_MAX_RECORDING_SECONDS=30

# Optional: Enable debug logging
# KADI_DEBUG=true
