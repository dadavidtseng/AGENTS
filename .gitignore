# ////////////////////////////////////////////////////////////////////////////////////////////////////
# .gitignore — AGENTS Monorepo
# ////////////////////////////////////////////////////////////////////////////////////////////////////
# Covers: DaemonEngine (C++20/DirectX/V8), AGENTS ecosystem (Node.js/TypeScript), Python agents
# ////////////////////////////////////////////////////////////////////////////////////////////////////

# ====================================================================================================
# IDE and Editor Files
# ====================================================================================================
# Visual Studio 2022
.vs/
.vsconfig
*.sln.DotSettings.user
*.user
*.suo
*.opensdf
*.sdf
*.VC.db
*.VC.opendb
*.vcxproj.user

# JetBrains IDEs (Rider, CLion) — keep .idea/.gitignore (JetBrains-managed)
.idea/

# VS Code
.vscode/
*.code-workspace

# Vim/Neovim
*.swp
*.swo

# Qodo / Qodo Gen
.qodo/
.qudo/

# ====================================================================================================
# Compiled Output — C/C++ (DaemonEngine)
# ====================================================================================================
# Prerequisites
*.d

# Compiled Object files
*.slo
*.lo
*.o
*.obj

# Precompiled Headers
*.gch
*.pch

# Compiled Dynamic libraries
*.so
*.dylib
*.dll

# Fortran module files
*.mod
*.smod

# Compiled Static libraries
*.lai
*.la
*.a
*.lib

# Executables
*.exe
*.out
*.app
*.ipa

# Debug symbols
*.pdb
*.ilk
*.idb
*.mdmp
*.dmp
*.stackdump

# ====================================================================================================
# Build Artifacts — C++ (DaemonEngine)
# ====================================================================================================
Build/
Binaries/
Plugins/**/Binaries/
Intermediate/
Plugins/**/Intermediate/
DerivedDataCache/

# Whitelist specific build configuration files
!Build/*/
Build/*/**
!Build/*/PakBlacklist*.txt
!Build/**/*.ico

# Generated project files
*.xcodeproj
*.xcworkspace

# ====================================================================================================
# Game Engine Specific (DaemonEngine)
# ====================================================================================================
Saved/
Save/
/Run/Logs/
*_BuiltData.uasset

# ====================================================================================================
# Node.js / TypeScript (AGENTS ecosystem)
# ====================================================================================================
node_modules/
dist/
build/
*.tsbuildinfo
*.tgz
package-lock.json
yarn.lock
pnpm-lock.yaml
.cache/
.parcel-cache
.eslintcache
.npm

# ====================================================================================================
# Python (template-agent-python)
# ====================================================================================================
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
.eggs/
.venv/
venv/
*.so
.mypy_cache/
.pytest_cache/
.coverage
htmlcov/

# ====================================================================================================
# KADI / AGENTS Specific
# ====================================================================================================
# Downloaded ability packages (generated by kadi install)
abilities/

# Agent dependency lock files
agent-lock.json

# Deployment lock files
.kadi-deploy.lock

# Astro build cache (agent-docs)
.astro/

# Agent runtime data
data/

# Crypto keys
*.key
*.pem

# ====================================================================================================
# Environment and Secrets
# ====================================================================================================
.env
.env.*
!.env.example

# ====================================================================================================
# Logs
# ====================================================================================================
*.log
*.log.*
Logs/
logs/

# ====================================================================================================
# Testing and Coverage
# ====================================================================================================
coverage/
.nyc_output/
TestResults/
*.trx
*.coverage

# ====================================================================================================
# Operating System Files
# ====================================================================================================
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Linux
*~
.directory

# ====================================================================================================
# Archive Files
# ====================================================================================================
*.zip
*.7z
*.rar
*.tar
*.gz
*.bz2

# ====================================================================================================
# Temporary Files
# ====================================================================================================
*.tmp
*.temp
*.dat
[Tt]emporary/
[Tt]emp/
CrashReports/

# ====================================================================================================
# Documentation Build Output
# ====================================================================================================
html/
latex/
docs/_build/

# ====================================================================================================
# AI Tooling (local working files)
# ====================================================================================================
.claude/
.serena/
.spec-workflow/

# ====================================================================================================
# NuGet (DaemonEngine dependencies)
# ====================================================================================================
packages/
*.nupkg
