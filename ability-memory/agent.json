{
  "name": "ability-memory",
  "type": "ability",
  "version": "0.0.8",
  "description": "Domain layer for conversational agent memory — thin wrapper over graph-ability providing 7 memory-* tools with enforced Memory schema defaults",
  "entrypoint": "dist/index.js",
  "abilities": {
    "graph-ability": "^0.0.7",
    "secret-ability": "^0.9.4"
  },
  "brokers": {
    "local": "ws://localhost:8080/kadi",
    "remote": "wss://broker.dadavidtseng.info/kadi"
  },
  "scripts": {
    "preflight": "node --version",
    "setup": "npm install && npm run build",
    "build": "npx tsc",
    "start": "node dist/index.js broker",
    "dev": "npx tsx src/index.ts",
    "clean": "rm -rf node_modules abilities agent-lock.json package-lock.json dist"
  },
  "build": {
    "default": {
      "image": "agent-memory-ability:1.0.0",
      "from": "node:22-slim",
      "platform": "linux/amd64",
      "cli": "latest",
      "run": [
        "npm ci",
        "npm run build",
        "kadi install kadi-install",
        "kadi install kadi-run",
        "kadi install kadi-secret",
        "kadi install"
      ],
      "cmd": [
        "sh",
        "-c",
        "kadi run start"
      ]
    }
  },
  "deploy": {
    "local": {
      "target": "local",
      "engine": "docker",
      "services": {
        "agent": {
          "image": "agent-memory-ability:1.0.0",
          "command": [
            "sh",
            "-c",
            "kadi secret receive --vault models && kadi run start"
          ]
        }
      },
      "secrets": {
        "vault": "models",
        "required": [
          "MEMORY_API_KEY",
          "MEMORY_API_URL"
        ],
        "delivery": "broker"
      }
    }
  }
}
