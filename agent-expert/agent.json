{
  "name": "agent-expert",
  "type": "agent",
  "version": "0.1.0",
  "description": "AGENTS developer assistant — answers questions, writes TDDs, provides guides",
  "entrypoint": "dist/index.js",
  "abilities": {
    "secret-ability": "*",
    "ability-log": "*"
  },
  "brokers": {
    "remote": "wss://broker.dadavidtseng.com/kadi"
  },
  "networks": ["global"],
  "scripts": {
    "setup": "npm run build",
    "start": "node dist/index.js",
    "dev": "npx tsx src/index.ts",
    "build": "npx tsc",
    "type-check": "npx tsc --noEmit",
    "lint": "npx eslint src --ext .ts",
    "test": "npx vitest",
    "clean": "rm -rf node_modules dist abilities agent-lock.json package-lock.json"
  },
  "build": {
    "default": {
      "from": "node:20-alpine",
      "cli": "latest",
      "run": [
        "npm ci --include=dev",
        "kadi install kadi-secret",
        "kadi install",
        "npx tsc",
        "npm prune --omit=dev"
      ],
      "env": {
        "NODE_ENV": "production"
      }
    }
  },
  "deploy": {
    "akash-mainnet": {
      "target": "akash",
      "network": "mainnet",
      "deposit": "10",
      "blacklist": [
        "akash1sevd2ymtty3dpq9ycxgkhuzzk4fe6mchqdwd4e",
        "akash14w36hwrtuqqa3j92fa8ctcxlhjgvr3a0zpp7cj"
      ],
      "engine": "podman",
      "services": {
        "app": {
          "image": "agent-expert:0.1.0",
          "command": ["sh", "-c", "kadi secret receive --vault model-manager --vault arcadedb && kadi run start"],
          "expose": [
            {
              "port": 3000,
              "as": 3000,
              "to": [{ "global": true }]
            }
          ],
          "env": [
            "NODE_ENV=production",
            "ARCADE_HOST=arcadedb.dadavidtseng.com",
            "ARCADE_PORT=443"
          ],
          "resources": {
            "cpu": 0.5,
            "memory": "512Mi",
            "ephemeralStorage": "1Gi"
          },
          "pricing": { "amount": "500", "denom": "uact" }
        }
      },
      "secrets": {
        "vaults": [
          {
            "vault": "model-manager",
            "required": ["MODEL_MANAGER_API_KEY", "MODEL_MANAGER_BASE_URL"]
          },
          {
            "vault": "arcadedb",
            "required": ["ARCADE_USERNAME", "ARCADE_PASSWORD"]
          }
        ],
        "delivery": "broker"
      }
    }
  }
}
