# TypeScript Agent with MCP Integration Configuration - PRODUCTION

# Agent Configuration
AGENT_NAME=template-typescript-agent
AGENT_VERSION=0.0.1
NODE_ENV=production

# Node.js TLS Configuration
# WARNING: Only use in development/staging environments!
NODE_TLS_REJECT_UNAUTHORIZED=0

# Memory Configuration
MEMORY_DATA_PATH=/app/data/memory

# ArcadeDB Configuration
ARCADEDB_URL=http://arcadedb:2480
ARCADEDB_USERNAME=root
ARCADEDB_PASSWORD=playwithdata
ARCADEDB_DATABASE=memory

# MCP Server Configuration
MCP_LOG_LEVEL=info
MCP_TRANSPORT_TYPE=stdio
MCP_RESPONSE_FORMAT=auto

# Claude API Configuration (for Slack/Discord bot responses)
ANTHROPIC_API_KEY=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

# Bot Feature Flags (set to true/false to enable/disable)
ENABLE_SLACK_BOT=true
ENABLE_DISCORD_BOT=true

# Bot Claude Configuration
# Claude model to use for processing mentions (default: claude-3-haiku-20240307)
BOT_CLAUDE_MODEL=claude-3-haiku-20240307

# Maximum tokens for Claude API responses (default: 4096)
BOT_CLAUDE_MAX_TOKENS=4096

# Slack Bot Configuration (REQUIRED when ENABLE_SLACK_BOT=true)
# Slack bot user ID for event subscription routing
# Get from Slack app settings > OAuth & Permissions (format: U followed by alphanumeric)
# TODO: Replace with your actual bot user ID
SLACK_BOT_USER_ID=U09SCDV78AK

# Discord Bot Configuration (REQUIRED when ENABLE_DISCORD_BOT=true)
DISCORD_BOT_USER_ID=1438685741751210025

# Bot Timing Configuration
# Tool invocation timeout in milliseconds (default: 10000 = 10 seconds)
BOT_TOOL_TIMEOUT_MS=10000

# Bot Resilience Configuration
# Maximum retry attempts for failed requests (default: 3)
BOT_MAX_RETRIES=3

# Base delay in milliseconds for exponential backoff (default: 1000)
BOT_RETRY_BASE_DELAY_MS=1000

# Maximum failures before circuit breaker opens (default: 5)
BOT_CIRCUIT_BREAKER_MAX_FAILURES=5

# Circuit breaker reset time in milliseconds (default: 60000 = 1 minute)
BOT_CIRCUIT_BREAKER_RESET_MS=60000

MODEL_MANAGER_BASE_URL=https://test-gateway.example.com
MODEL_MANAGER_API_KEY=test-env-api-key-12345