{
  "name": "agent-worker",
  "version": "0.3.2",
  "description": "Generic worker agent for KĀDI multi-agent system (supports artist, programmer, designer roles via config)",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "start:artist": "cross-env AGENT_ROLE=artist node dist/index.js",
    "start:designer": "cross-env AGENT_ROLE=designer node dist/index.js",
    "start:programmer": "cross-env AGENT_ROLE=programmer node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "dev:artist": "cross-env AGENT_ROLE=artist tsx watch src/index.ts",
    "dev:designer": "cross-env AGENT_ROLE=designer tsx watch src/index.ts",
    "dev:programmer": "cross-env AGENT_ROLE=programmer tsx watch src/index.ts",
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest"
  },
  "keywords": [
    "kadi",
    "agent",
    "template",
    "multi-agent",
    "typescript"
  ],
  "author": "Yu-Wei Tseng",
  "license": "Apache License 2.0",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@kadi.build/core": "latest",
    "@modelcontextprotocol/sdk": "1.26.0",
    "agents-library": "latest",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitest/coverage-v8": "^4.1.2",
    "cross-env": "^10.1.0",
    "eslint": "^8.56.0",
    "patch-package": "^8.0.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
