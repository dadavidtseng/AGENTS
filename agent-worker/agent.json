{
  "name": "agent-worker",
  "type": "agent",
  "version": "0.3.1",
  "entrypoint": "dist/index.js",
  "scripts": {
    "preflight": "node --version",
    "setup": "npm run build",
    "start": "node dist/index.js",
    "start:artist": "AGENT_ROLE=artist node dist/index.js",
    "start:designer": "AGENT_ROLE=designer node dist/index.js",
    "start:programmer": "AGENT_ROLE=programmer node dist/index.js",
    "dev": "npx tsx watch src/index.ts",
    "dev:artist": "AGENT_ROLE=artist npx tsx watch src/index.ts",
    "dev:designer": "AGENT_ROLE=designer npx tsx watch src/index.ts",
    "dev:programmer": "AGENT_ROLE=programmer npx tsx watch src/index.ts",
    "build": "npx tsc",
    "type-check": "npx tsc --noEmit",
    "lint": "npx eslint src --ext .ts",
    "test": "npx vitest",
    "clean": "rm -rf node_modules dist abilities agent-lock.json package-lock.json"
  },
  "build": {
    "default": {
      "from": "node:20-alpine",
      "cli": "latest",
      "run": [
        "npm ci --include=dev",
        "kadi install kadi-secret",
        "kadi install",
        "npx tsc",
        "npm prune --omit=dev"
      ],
      "env": {
        "NODE_ENV": "production"
      }
    }
  },
  "deploy": {
    "do-programmer": {
      "target": "local",
      "engine": "docker",
      "services": {
        "app": {
          "image": "agent-worker:0.3.1",
          "command": ["sh", "-c", "kadi secret receive --vault anthropic --vault model-manager && kadi run start:programmer"],
          "env": [
            "NODE_ENV=production",
            "AGENT_ROLE=programmer"
          ],
          "volumes": [
            "~/agent-playground/programmer:/app/playground"
          ],
          "restart": "unless-stopped"
        }
      },
      "secrets": {
        "vaults": [
          { "vault": "anthropic", "required": ["ANTHROPIC_API_KEY"] },
          { "vault": "model-manager", "required": ["MODEL_MANAGER_API_KEY", "MODEL_MANAGER_BASE_URL"] }
        ],
        "delivery": "broker"
      }
    },
    "do-artist": {
      "target": "local",
      "engine": "docker",
      "services": {
        "app": {
          "image": "agent-worker:0.3.1",
          "command": ["sh", "-c", "kadi secret receive --vault anthropic --vault model-manager && kadi run start:artist"],
          "env": [
            "NODE_ENV=production",
            "AGENT_ROLE=artist"
          ],
          "volumes": [
            "~/agent-playground/artist:/app/playground"
          ],
          "restart": "unless-stopped"
        }
      },
      "secrets": {
        "vaults": [
          { "vault": "anthropic", "required": ["ANTHROPIC_API_KEY"] },
          { "vault": "model-manager", "required": ["MODEL_MANAGER_API_KEY", "MODEL_MANAGER_BASE_URL"] }
        ],
        "delivery": "broker"
      }
    },
    "do-designer": {
      "target": "local",
      "engine": "docker",
      "services": {
        "app": {
          "image": "agent-worker:0.3.1",
          "command": ["sh", "-c", "kadi secret receive --vault anthropic --vault model-manager && kadi run start:designer"],
          "env": [
            "NODE_ENV=production",
            "AGENT_ROLE=designer"
          ],
          "volumes": [
            "~/agent-playground/designer:/app/playground"
          ],
          "restart": "unless-stopped"
        }
      },
      "secrets": {
        "vaults": [
          { "vault": "anthropic", "required": ["ANTHROPIC_API_KEY"] },
          { "vault": "model-manager", "required": ["MODEL_MANAGER_API_KEY", "MODEL_MANAGER_BASE_URL"] }
        ],
        "delivery": "broker"
      }
    },
    "do-all": {
      "target": "local",
      "engine": "docker",
      "services": {
        "programmer": {
          "image": "agent-worker:0.3.1",
          "command": ["sh", "-c", "kadi secret receive --vault anthropic --vault model-manager && kadi run start:programmer"],
          "env": ["NODE_ENV=production", "AGENT_ROLE=programmer"],
          "volumes": ["~/agent-playground/programmer:/app/playground"],
          "restart": "unless-stopped"
        },
        "artist": {
          "image": "agent-worker:0.3.1",
          "command": ["sh", "-c", "kadi secret receive --vault anthropic --vault model-manager && kadi run start:artist"],
          "env": ["NODE_ENV=production", "AGENT_ROLE=artist"],
          "volumes": ["~/agent-playground/artist:/app/playground"],
          "restart": "unless-stopped"
        },
        "designer": {
          "image": "agent-worker:0.3.1",
          "command": ["sh", "-c", "kadi secret receive --vault anthropic --vault model-manager && kadi run start:designer"],
          "env": ["NODE_ENV=production", "AGENT_ROLE=designer"],
          "volumes": ["~/agent-playground/designer:/app/playground"],
          "restart": "unless-stopped"
        }
      },
      "secrets": {
        "vaults": [
          { "vault": "anthropic", "required": ["ANTHROPIC_API_KEY"] },
          { "vault": "model-manager", "required": ["MODEL_MANAGER_API_KEY", "MODEL_MANAGER_BASE_URL"] }
        ],
        "delivery": "broker"
      }
    }
  },
  "abilities": {
    "secret-ability": "*",
    "ability-file-local": "*"
  },
  "brokers": {
    "local": "ws://localhost:8080/kadi",
    "remote": "wss://broker.dadavidtseng.com/kadi"
  }
}