# ============================================================================
# Agent_TypeScript - Production Dockerfile
# ============================================================================
# Multi-stage build for optimal image size
# ============================================================================

# -----------------------------------------------------------------------------
# Stage 1: Build
# -----------------------------------------------------------------------------
FROM node:20-alpine AS builder

WORKDIR /app

# Copy kadi-core (local file dependency) and build it first
COPY kadi/kadi-core ./kadi-core
WORKDIR /app/kadi-core
RUN npm ci && npm run build

# Go back to app root and copy Agent_TypeScript
WORKDIR /app
COPY Agent_TypeScript/package*.json ./

# Create a symlink to make the local file dependency work
RUN mkdir -p /kadi && ln -s /app/kadi-core /kadi/kadi-core

# Install ALL dependencies (including devDependencies for build)
RUN npm ci

# Copy Agent_TypeScript source code
COPY Agent_TypeScript/. .

# Build TypeScript
RUN npm run build

# -----------------------------------------------------------------------------
# Stage 2: Production Runtime
# -----------------------------------------------------------------------------
FROM node:20-alpine

WORKDIR /app

# Copy built kadi-core from builder stage
COPY --from=builder /app/kadi-core ./kadi-core

# Create the symlink structure for local file dependency
RUN mkdir -p /kadi && ln -s /app/kadi-core /kadi/kadi-core

# Copy package files from Agent_TypeScript
COPY Agent_TypeScript/package*.json ./

# Install ONLY production dependencies
RUN npm ci --omit=dev

# Copy built files from builder stage
COPY --from=builder /app/dist ./dist

# Expose no ports (this is a client service connecting to broker)

# Start agent
CMD ["node", "dist/index.js"]
